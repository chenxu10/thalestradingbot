#!/bin/bash
# pre-push hook: run the full test suite AND the function-length power-law
# alpha gate before any push.
#
# Policy: the test suite must pass (a failure blocks the push). The alpha
# gate is ADVISORY ONLY: it reports whether the fitted power-law exponent
# alpha of the function-length distribution regressed vs the last approved
# push and prints a top-3 table (line count, # functions, name, location)
# of the longest functions worth refactoring — but never blocks the push.
# A higher alpha means a lighter tail = fewer extreme-long functions = lower
# complexity and less exposure to accidental tail events. See
# fentu/metaprogramming/function_length_powerlaw.py (Clauset-Shalizi-Newman
# 2009 / isitapowerlaw.com).
#
# Install by copying to .git/hooks/pre-push and making it executable:
#   cp .githooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

set -e

# --- 1) full test suite ----------------------------------------------------
echo "Running test suite before push..."
if command -v uv >/dev/null 2>&1; then
    uv run pytest -q
elif [ -f .venv/bin/python ]; then
    .venv/bin/python -m pytest -q
elif [ -f venv/bin/python ]; then
    venv/bin/python -m pytest -q
else
    python -m pytest -q
fi
echo "All tests passed."

# --- 2) function-length power-law alpha gate (advisory) --------------------
# Reports alpha vs the last approved push and the top-3 refactor table; never
# blocks the push.
echo "Running function-length power-law alpha gate (advisory)..."
if command -v uv >/dev/null 2>&1; then
    uv run python -m fentu.metaprogramming.function_length_powerlaw --hook
elif [ -f .venv/bin/python ]; then
    .venv/bin/python -m fentu.metaprogramming.function_length_powerlaw --hook
else
    python -m fentu.metaprogramming.function_length_powerlaw --hook
fi

echo "Alpha gate report done (advisory). Proceeding with push."
