#!/bin/bash
# pre-push hook: run the full test suite AND the function-length power-law
# alpha gate before allowing any push.
#
# Policy: the fitted power-law exponent alpha of the function-length
# distribution must NOT regress (it must be higher than the last approved
# push, or the tree must be unchanged since the last approved push). A higher
# alpha means a lighter tail = fewer extreme-long functions = lower complexity
# and less exposure to accidental tail events. See
# fentu/metaprogramming/function_length_powerlaw.py (Clauset-Shalizi-Newman
# 2009 / isitapowerlaw.com).
#
# Install by copying to .git/hooks/pre-push and making it executable:
#   cp .githooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
#
# Emergency bypass (tests below still run):
#   FORCE_PUSH=1 git push ...

set -e

# --- 1) full test suite ----------------------------------------------------
echo "Running test suite before push..."
if command -v uv >/dev/null 2>&1; then
    uv run pytest -q
elif [ -f .venv/bin/python ]; then
    .venv/bin/python -m pytest -q
elif [ -f venv/bin/python ]; then
    venv/bin/python -m pytest -q
else
    python -m pytest -q
fi
echo "All tests passed."

# --- 2) function-length power-law alpha gate -------------------------------
# Blocks the push unless alpha increased vs the last approved push (or the tree
# is unchanged since the last approved push). FORCE_PUSH=1 bypasses this gate.
echo "Running function-length power-law alpha gate..."
if command -v uv >/dev/null 2>&1; then
    uv run python -m fentu.metaprogramming.function_length_powerlaw --hook
elif [ -f .venv/bin/python ]; then
    .venv/bin/python -m fentu.metaprogramming.function_length_powerlaw --hook
else
    python -m fentu.metaprogramming.function_length_powerlaw --hook
fi

echo "Alpha gate passed. Proceeding with push."
